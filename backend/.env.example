# Copy this file to `.env` and edit as needed.
# For local dev the default SQLite URL works with zero setup.
#
# Examples:
#   SQLite (default, no install required):
#     DATABASE_URL=sqlite:///./fortune.db
#
#   PostgreSQL (once you have Postgres running):
#     DATABASE_URL=postgresql+psycopg2://fortune:fortune@localhost:5432/fortune

DATABASE_URL=sqlite:///./fortune.db

# CORS: comma-separated list of origins allowed to call the API.
# In local dev, Vite runs on 5173.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- OpenAI (optional) -------------------------------------------------
# If OPENAI_API_KEY is set, the /random endpoint will ask the LLM for a
# fresh one-line fortune. If it's missing, empty, or the API call fails
# for any reason, the app silently falls back to a random seed message.
#
# Get a key at https://platform.openai.com/api-keys
# Costs ~$0.0001 per fortune on gpt-4o-mini.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=5
